# 复制到 /etc/nginx/sites-available/hechengdalvdian 后启用
# sudo ln -s .../hechengdalvdian /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name hechengdalvdian.xuanxuan.com;

    root /var/www/hechengdalvdian;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # 音频、图片缓存
    location ~* \.(m4a|mp3|flac|jpg|jpeg|png|webp|gif|js|css)$ {
        expires 7d;
        add_header Cache-Control "public";
    }

    # 中文路径资源
    charset utf-8;
}
